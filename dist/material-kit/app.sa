  store dom+sax_LayoutSection_node_section, node_0 as i64
  call @sax_dom_set_str_prop(node_0, *sax_LayoutSection_5, 9, *sax_LayoutSection_6, 6)
  node_1 = call @sax_dom_create(*sax_LayoutSection_7, 4)
  store dom+sax_LayoutSection_node_Slot, node_1 as i64
  call @sax_dom_append_child(node_0, node_1)
  call @sax_dom_append_child(parent_h, node_0)
  call @sax_layoutsection_render(ctx)
  return ctx

@export sax_layoutsection_slot(ctx: ptr) -> i64:
