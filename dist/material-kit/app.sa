@export sax_layoutsection_init() -> ptr:
L_ENTRY:
  ctx = call @sax_layoutsection_init_ffi()
  return ctx

@ffi_wrapper sax_layoutsection_init_ffi() -> ptr:
L_ENTRY:
  host = call @sax_dom_query(*sax_LayoutSection_host_app, 4)
  state = alloc LayoutSection_SIZE
  dom = alloc LayoutSection_dom_SIZE
  ctx = alloc LayoutSection_CTX_SIZE
  store ctx+LayoutSection_CTX_state, state as ptr
  store ctx+LayoutSection_CTX_dom, dom as ptr
  node_0 = call @sax_dom_create(*sax_LayoutSection_0, 7)
  store dom+sax_LayoutSection_node_section, node_0 as i64
  call @sax_dom_set_str_prop(node_0, *sax_LayoutSection_2, 9, *sax_LayoutSection_3, 6)
  node_1 = call @sax_dom_create(*sax_LayoutSection_4, 4)
  store dom+sax_LayoutSection_node_Slot, node_1 as i64
  call @sax_dom_append_child(node_0, node_1)
  call @sax_dom_append_child(host, node_0)
  call @sax_layoutsection_render(ctx)
  return ctx

@export sax_layoutsection_mount(parent_h: i64) -> ptr:
L_ENTRY:
