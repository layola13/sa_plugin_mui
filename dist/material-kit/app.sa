  return ctx

@ffi_wrapper sax_layoutsection_mount_ffi(parent_h: i64) -> ptr:
L_ENTRY:
  state = alloc LayoutSection_SIZE
  dom = alloc LayoutSection_dom_SIZE
  ctx = alloc LayoutSection_CTX_SIZE
