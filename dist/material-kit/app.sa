@export sax_circularprogress_destroy(ctx: ptr):
L_ENTRY:
  call @sax_circularprogress_destroy_ffi(ctx)
  return

@ffi_wrapper sax_circularprogress_destroy_ffi(ctx: ptr):
L_ENTRY:
  state = load ctx+CircularProgress_CTX_state as ptr
  dom = load ctx+CircularProgress_CTX_dom as ptr
  node_0 = load dom+sax_CircularProgress_node_span as ptr
  call @sax_dom_remove_self(node_0)
  node_1 = load dom+sax_CircularProgress_node_svg as ptr
  call @sax_dom_remove_self(node_1)
  node_2 = load dom+sax_CircularProgress_node_circle as ptr
  call @sax_dom_remove_self(node_2)
  color = load state+CircularProgress_color as ptr
  !color
  color_len = load state+CircularProgress_color_len as i64
  !color_len
  disableShrink = load state+CircularProgress_disableShrink as i1
  !disableShrink
  size = load state+CircularProgress_size as i64
  !size
  thickness = load state+CircularProgress_thickness as i64
  !thickness
  value = load state+CircularProgress_value as i64
  !value
  variant = load state+CircularProgress_variant as ptr
  !variant
  variant_len = load state+CircularProgress_variant_len as i64
  !variant_len
  !dom
  !state
  !ctx
  return

