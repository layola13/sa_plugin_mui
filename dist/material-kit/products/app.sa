#def NavUpgrade_SIZE = 32
#def NavUpgrade_dom_SIZE = 32
#def NavUpgrade_CTX_SIZE = 16
#def NavUpgrade_CTX_state = +0
#def NavUpgrade_CTX_dom = +8

#def NavUpgrade_title = +0
#def NavUpgrade_title_len = +8
#def NavUpgrade_subtitle = +16
#def NavUpgrade_subtitle_len = +24

#def sax_NavUpgrade_node_section = +0
#def sax_NavUpgrade_node_img = +8
#def sax_NavUpgrade_node_strong = +16
#def sax_NavUpgrade_node_span = +24

@export sax_navupgrade_init() -> ptr:
L_ENTRY:
  ctx = call @sax_navupgrade_init_ffi()
  return ctx

@ffi_wrapper sax_navupgrade_init_ffi() -> ptr:
L_ENTRY:
  host = call @sax_dom_query(*sax_NavUpgrade_host_app, 4)
  state = alloc NavUpgrade_SIZE
  tmp_ptr_0 = alloc 32
  call @sax_mem_copy(*tmp_ptr_0, *sax_NavUpgrade_4, 16)
  store state+NavUpgrade_title, tmp_ptr_0 as ptr
  store state+NavUpgrade_title_len, 16 as i64
  tmp_ptr_2 = alloc 47
  call @sax_mem_copy(*tmp_ptr_2, *sax_NavUpgrade_5, 47)
  store state+NavUpgrade_subtitle, tmp_ptr_2 as ptr
  store state+NavUpgrade_subtitle_len, 47 as i64
  dom = alloc NavUpgrade_dom_SIZE
  ctx = alloc NavUpgrade_CTX_SIZE
  store ctx+NavUpgrade_CTX_state, state as ptr
  store ctx+NavUpgrade_CTX_dom, dom as ptr
  node_0 = call @sax_dom_create(*sax_NavUpgrade_0, 7)
  store dom+sax_NavUpgrade_node_section, node_0 as i64
  call @sax_dom_set_str_prop(node_0, *sax_NavUpgrade_6, 9, *sax_NavUpgrade_7, 10)
  node_1 = call @sax_dom_create(*sax_NavUpgrade_1, 3)
  store dom+sax_NavUpgrade_node_img, node_1 as i64
  call @sax_dom_set_str_prop(node_1, *sax_NavUpgrade_8, 3, *sax_NavUpgrade_9, 48)
  call @sax_dom_set_str_prop(node_1, *sax_NavUpgrade_10, 3, *sax_NavUpgrade_11, 22)
  node_2 = call @sax_dom_create(*sax_NavUpgrade_2, 6)
  store dom+sax_NavUpgrade_node_strong, node_2 as i64
  node_3 = call @sax_dom_create(*sax_NavUpgrade_3, 4)
  store dom+sax_NavUpgrade_node_span, node_3 as i64
  call @sax_dom_append_child(node_0, node_1)
  call @sax_dom_append_child(node_0, node_2)
  call @sax_dom_append_child(node_0, node_3)
  call @sax_dom_append_child(host, node_0)
  call @sax_navupgrade_render(ctx)
  return ctx

@export sax_navupgrade_mount(parent_h: i64) -> ptr:
L_ENTRY:
  ctx = call @sax_navupgrade_mount_ffi(parent_h)
  return ctx

@ffi_wrapper sax_navupgrade_mount_ffi(parent_h: i64) -> ptr:
L_ENTRY:
  state = alloc NavUpgrade_SIZE
  tmp_ptr_0 = alloc 32
  call @sax_mem_copy(*tmp_ptr_0, *sax_NavUpgrade_12, 16)
  store state+NavUpgrade_title, tmp_ptr_0 as ptr
  store state+NavUpgrade_title_len, 16 as i64
  tmp_ptr_2 = alloc 47
