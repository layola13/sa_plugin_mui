@export sax_workspacespopover_init() -> ptr:
L_ENTRY:
  ctx = call @sax_workspacespopover_init_ffi()
  return ctx

@ffi_wrapper sax_workspacespopover_init_ffi() -> ptr:
L_ENTRY:
  host = call @sax_dom_query(*sax_WorkspacesPopover_host_app, 4)
  state = alloc WorkspacesPopover_SIZE
  store state+WorkspacesPopover_workspace_open, 0 as i1
  store state+WorkspacesPopover_workspace_hidden, 1 as i1
  store state+WorkspacesPopover_workspace_team1, 1 as i1
  store state+WorkspacesPopover_workspace_team2, 0 as i1
