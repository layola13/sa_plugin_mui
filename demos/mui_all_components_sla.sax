      <svg className="MuiSvgIcon-root MuiSvgIcon-fontSizeMedium" focusable="false" aria-hidden="true">
        <path d="M4 12l1.41 1.41L11 7.83V20h2V7.83l5.59 5.6L20 12 12 4z" />
      </svg>
    </span>
  </span>
  !active !direction !direction_len !hideSortIcon
</Component>

<Component name="TablePaginationActions">
  <state>
    count = 0
    disabled = 0 as i1
    page = 0
    rowsPerPage = 10
    showFirstButton = 0 as i1
    showLastButton = 0 as i1
  </state>
  <div className="MuiTablePaginationActions-root">
    <button className="MuiButtonBase-root MuiIconButton-root MuiIconButton-colorInherit MuiIconButton-sizeMedium" aria-label="Go to previous page">
      <svg className="MuiSvgIcon-root MuiSvgIcon-fontSizeMedium" focusable="false" aria-hidden="true">
        <path d="M15.41 7.41 14 6l-6 6 6 6 1.41-1.41L10.83 12z" />
      </svg>
    </button>
    <button className="MuiButtonBase-root MuiIconButton-root MuiIconButton-colorInherit MuiIconButton-sizeMedium" aria-label="Go to next page">
      <svg className="MuiSvgIcon-root MuiSvgIcon-fontSizeMedium" focusable="false" aria-hidden="true">
        <path d="m10 6 6 6-6 6-1.41-1.41L13.17 12 8.59 7.41z" />
      </svg>
    </button>
    <Slot />
  </div>
  !count !disabled !page !rowsPerPage !showFirstButton !showLastButton
</Component>

<Component name="TablePagination">
  <state>
    count = 0
    disabled = 0 as i1
    labelRowsPerPage = alloc 64
    labelRowsPerPage_len = 14
    page = 0
    rowsPerPage = 10
    showFirstButton = 0 as i1
    showLastButton = 0 as i1
  </state>
  <td className="MuiTableCell-root MuiTableCell-footer MuiTablePagination-root" colspan="1000">
    <div className="MuiToolbar-root MuiToolbar-gutters MuiToolbar-regular MuiTablePagination-toolbar">
      <div className="MuiTablePagination-spacer" />
      <p className="MuiTablePagination-selectLabel">Rows per page:</p>
      <div className="MuiInputBase-root MuiTablePagination-input">
        <select className="MuiTablePagination-select" />
      </div>
      <p className="MuiTablePagination-displayedRows">0-0 of 0</p>
      <div className="MuiTablePagination-actions">
        <TablePaginationActions />
      </div>
      <Slot />
    </div>
  </td>
  !count !disabled !labelRowsPerPage !labelRowsPerPage_len !page !rowsPerPage !showFirstButton !showLastButton
</Component>

<Component name="Typography">
  <state>
    align = alloc 16
    align_len = 7
    gutterBottom = 0 as i1
    noWrap = 0 as i1
    variant = alloc 32
    variant_len = 5
  </state>
  <p className="MuiTypography-root MuiTypography-body1">
    <Slot />
  </p>
  !align !align_len !gutterBottom !noWrap !variant !variant_len
</Component>
