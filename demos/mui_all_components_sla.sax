<Component name="MuiAllComponents">
  <section className="mui-basic-demo">
    <InitColorSchemeScript />
    <GlobalStyles />
    <CssBaseline />
    <Container>
      <AppBar>
        <Toolbar>
          <Typography>Toolbar title</Typography>
        </Toolbar>
      </AppBar>
      <Typography>SA driven MUI</Typography>
      <Paper>
        <Stack>
          <Button>Save</Button>
          <ButtonGroup>
            <ButtonBase>Base</ButtonBase>
            <Button>Grouped</Button>
          </ButtonGroup>
          <IconButton>Icon</IconButton>
          <Fab>Add</Fab>
          <FormControl>
            <FormLabel>Email</FormLabel>
            <InputLabel>Email input</InputLabel>
            <Input>
              <InputAdornment>$</InputAdornment>
            </Input>
            <InputBase>Base input</InputBase>
            <FilledInput>Filled input</FilledInput>
            <OutlinedInput>Outlined input</OutlinedInput>
            <TextField>Text field</TextField>
            <TextareaAutosize>Textarea</TextareaAutosize>
            <Select>
              <MenuItem>First option</MenuItem>
              <MenuItem>Second option</MenuItem>
            </Select>
            <NativeSelect>
              <option>Native option</option>
            </NativeSelect>
            <MenuList>
              <MenuItem>Menu option</MenuItem>
            </MenuList>
            <Menu open>
              <MenuItem>Menu child</MenuItem>
            </Menu>
            <Popover open>Popover content</Popover>
            <Popper open>Popper content</Popper>
            <Portal>Portal content</Portal>
            <Modal open>Modal content</Modal>
            <Drawer open>Drawer content</Drawer>
            <SwipeableDrawer open>Swipeable drawer content</SwipeableDrawer>
            <Slide in>Slide content</Slide>
            <Fade in>Fade content</Fade>
            <Grow in>Grow content</Grow>
            <Zoom in>Zoom content</Zoom>
            <Stepper>
              <Step>
                <StepLabel>First step</StepLabel>
                <StepContent>Step content</StepContent>
              </Step>
              <StepConnector />
              <Step>
                <StepButton>Second step</StepButton>
              </Step>
            </Stepper>
            <StepIcon />
            <Tabs>
              <Tab>First tab</Tab>
              <Tab>Second tab</Tab>
            </Tabs>
            <TabScrollButton />
            <ToggleButtonGroup>
              <ToggleButton>Bold</ToggleButton>
              <ToggleButton>Italic</ToggleButton>
            </ToggleButtonGroup>
            <Pagination>
              <PaginationItem selected>3</PaginationItem>
            </Pagination>
            <SpeedDial open>
              <SpeedDialIcon />
              <SpeedDialAction>Edit</SpeedDialAction>
              <SpeedDialAction>Share</SpeedDialAction>
            </SpeedDial>
            <Tooltip title="Tooltip label" open>
              <Button>Tooltip target</Button>
            </Tooltip>
            <Autocomplete open>
              <span>Selected option</span>
            </Autocomplete>
            <Rating value={3} />
            <Slider value={40} />
            <Collapse in>Collapsed content</Collapse>
            <SvgIcon>
              <path d="M12 2 2 22h20z" />
            </SvgIcon>
            <Icon>home</Icon>
            <Link>Open link</Link>
            <FormGroup>
              <FormControlLabel>
                <Checkbox />
              </FormControlLabel>
              <Switch />
              <FormHelperText>Required field</FormHelperText>
            </FormGroup>
            <RadioGroup>
              <Radio />
              <Radio />
            </RadioGroup>
          </FormControl>
          <Badge badgeContent={3}>
            <Chip>Status</Chip>
          </Badge>
          <BottomNavigation>
            <BottomNavigationAction>Home</BottomNavigationAction>
            <BottomNavigationAction>Settings</BottomNavigationAction>
          </BottomNavigation>
          <Breadcrumbs>
            <span>Home</span>
            <span>Library</span>
          </Breadcrumbs>
          <ScopedCssBaseline>
            <Grid>
              <NoSsr>Client content</NoSsr>
              <ClickAwayListener>Click away content</ClickAwayListener>
              <Unstable_TrapFocus open>Focus content</Unstable_TrapFocus>
            </Grid>
          </ScopedCssBaseline>
          <Divider />
          <Box>Box content</Box>
          <Alert>
            <AlertTitle>Heads up</AlertTitle>
            Check the SA driven MUI surface.
          </Alert>
          <Accordion>
            <AccordionSummary>Accordion summary</AccordionSummary>
            <AccordionDetails>Accordion details</AccordionDetails>
            <AccordionActions>
              <Button>Close</Button>
            </AccordionActions>
          </Accordion>
          <Backdrop open>Backdrop</Backdrop>
          <CircularProgress />
          <LinearProgress />
          <Skeleton>Loading</Skeleton>
          <Snackbar open>Snackbar message</Snackbar>
          <SnackbarContent>Snackbar content</SnackbarContent>
          <MobileStepper>
            <Button>Back</Button>
            <Button>Next</Button>
          </MobileStepper>
          <Dialog open>
            <DialogTitle>Dialog title</DialogTitle>
            <DialogContent>
              <DialogContentText>Dialog body</DialogContentText>
            </DialogContent>
            <DialogActions>
              <Button>Cancel</Button>
              <Button>Ok</Button>
            </DialogActions>
          </Dialog>
          <Card>
            <CardHeader>Card header</CardHeader>
            <CardActionArea>
              <CardMedia>Action media</CardMedia>
            </CardActionArea>
            <CardMedia>Media</CardMedia>
            <CardContent>
              <Typography>Card content</Typography>
              <AvatarGroup>
                <Avatar>A</Avatar>
                <Avatar>B</Avatar>
              </AvatarGroup>
              <ImageList>
                <ImageListItem>
                  <img />
                  <ImageListItemBar>Image title</ImageListItemBar>
                </ImageListItem>
              </ImageList>
              <List>
                <ListSubheader>Recent</ListSubheader>
                <ListItem>
                  <ListItemAvatar>
                    <Avatar>I</Avatar>
                  </ListItemAvatar>
                  <ListItemIcon>*</ListItemIcon>
                  <ListItemText>Inbox</ListItemText>
                  <ListItemSecondaryAction>
                    <IconButton>More</IconButton>
                  </ListItemSecondaryAction>
                </ListItem>
                <ListItemButton>
                  <ListItemText>Open inbox</ListItemText>
                </ListItemButton>
              </List>
              <TableContainer>
                <Table>
                  <TableHead>
                    <TableRow>
                      <TableCell>
                        <TableSortLabel>Name</TableSortLabel>
                      </TableCell>
                    </TableRow>
                  </TableHead>
                  <TableBody>
                    <TableRow>
                      <TableCell>Value</TableCell>
                    </TableRow>
                  </TableBody>
                  <TableFooter>
                    <TableRow>
                      <TablePagination />
                    </TableRow>
                  </TableFooter>
                </Table>
              </TableContainer>
              <TablePaginationActions />
            </CardContent>
            <CardActions>
              <Button>Open</Button>
            </CardActions>
          </Card>
        </Stack>
      </Paper>
    </Container>
  </section>
</Component>

