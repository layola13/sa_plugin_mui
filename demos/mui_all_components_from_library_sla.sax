            <TreeItem nodeId="root" label="Dashboard tree" expanded level={1}>
              <TreeItem nodeId="finance" label="Finance tree item" selected level={2} />
              <TreeItem nodeId="disabled" label="Disabled tree item" disabled level={2} />
            </TreeItem>
          </SimpleTreeView>
          <Dialog open>
            <DialogTitle>Dialog title</DialogTitle>
            <DialogContent>
              <DialogContentText>Dialog body</DialogContentText>
            </DialogContent>
            <DialogContent dividers>
              Divided dialog content
            </DialogContent>
            <DialogActions>
              <Button>Cancel</Button>
              <Button>Ok</Button>
            </DialogActions>
            <DialogActions disableSpacing>
              <Button>Tight dialog action</Button>
            </DialogActions>
          </Dialog>
          <Dialog open fullWidth fullScreen>
            <DialogContent>
              Full screen dialog body
            </DialogContent>
          </Dialog>
          <Dialog open scroll="body" maxWidth="md">
            <DialogContent>
              Body scroll medium dialog body
            </DialogContent>
          </Dialog>
          <Card>
            <CardHeader title="Card header title" subheader="Card header subheader">Card header slot</CardHeader>
            <CardHeader disableTypography title="Plain card title" subheader="Plain card subheader">Plain card slot</CardHeader>
            <CardActionArea disabled>
              <CardMedia>Action media</CardMedia>
            </CardActionArea>
            <CardMedia>Media</CardMedia>
            <CardMedia image="assets/mui_demo_cover.webp">Image media</CardMedia>
            <CardMedia component="img" src="assets/mui_demo_inline.webp">Img media</CardMedia>
            <CardContent>
              <Typography>Card content</Typography>
              <AvatarGroup>
                <Avatar>A</Avatar>
                <Avatar variant="rounded">R</Avatar>
                <Avatar src="assets/mui_demo_avatar.webp" srcSet="assets/mui_demo_avatar@2x.webp 2x" alt="Avatar image">Image avatar</Avatar>
                <Avatar>B</Avatar>
              </AvatarGroup>
              <AvatarGroup variant="rounded" className="library-avatar-group">
                <Avatar>Inherited group avatar</Avatar>
                <Avatar variant="square">Explicit group avatar</Avatar>
              </AvatarGroup>
              <ImageList cols={3} gap={8} rowHeight="240">
                <ImageListItem cols={2} rows={3}>
                  <img />
                  <ImageListItemBar title="Image title" subtitle="Image subtitle" actionIcon="More">Image title</ImageListItemBar>
                </ImageListItem>
                <ImageListItem variant="woven" cols={1} rows={2}>
                  <img />
                  <ImageListItemBar position="top" actionPosition="left" title="Woven image title" subtitle="Woven image subtitle" actionIcon="Share">Woven image title</ImageListItemBar>
                </ImageListItem>
              </ImageList>
              <List>
                <ListSubheader>Recent</ListSubheader>
                <ListSubheader color="primary">Primary recent</ListSubheader>
                <ListSubheader color="inherit">Inherited recent</ListSubheader>
                <ListItem>
                  <ListItemAvatar>
                    <Avatar>I</Avatar>
                  </ListItemAvatar>
                  <ListItemIcon>*</ListItemIcon>
                  <ListItemText>Inbox</ListItemText>
                  <ListItemSecondaryAction>
                    <IconButton>More</IconButton>
                  </ListItemSecondaryAction>
                </ListItem>
                <ListItemButton selected>
                  <ListItemText>Open inbox</ListItemText>
                </ListItemButton>
                <ListItemButton disabled>
                  <ListItemText>Disabled inbox</ListItemText>
                </ListItemButton>
              </List>
              <List dense disablePadding>
                <ListSubheader inset disableGutters disableSticky>Compact recent</ListSubheader>
                <ListItem divider disableGutters disablePadding>
                  <ListItemText inset>Dense divided item</ListItemText>
                  <ListItemSecondaryAction>
                    <IconButton>Compact more</IconButton>
                  </ListItemSecondaryAction>
                </ListItem>
                <ListItem>
                  <ListItemText primary="Main inbox" secondary="Two unread messages">Multiline list text</ListItemText>
                </ListItem>
                <ListItem>
                  <ListItemText disableTypography primary="Plain primary" secondary="Plain secondary">Plain list slot</ListItemText>
                </ListItem>
                <ListItemButton divider disableGutters selected>
                  <ListItemText>Dense selected action</ListItemText>
                </ListItemButton>
              </List>
              <TableContainer>
                <Table stickyHeader>
                  <TableHead>
                    <TableRow hover selected>
                      <TableCell stickyHeader>
                        <TableSortLabel active>Name</TableSortLabel>
                      </TableCell>
                      <TableCell>
                        <TableSortLabel direction="desc">Descending</TableSortLabel>
                      </TableCell>
                    </TableRow>
                  </TableHead>
                  <TableBody>
                    <TableRow>
                      <TableCell size="small">Value</TableCell>
                    </TableRow>
                  </TableBody>
                  <TableFooter>
                    <TableRow>
                      <TablePagination />
                    </TableRow>
                    <TableRow>
                      <TablePagination className="library-pagination-controls" classes={{ root: "library-pagination-root", toolbar: "library-pagination-toolbar", spacer: "library-pagination-spacer", selectLabel: "library-pagination-select-label", input: "library-pagination-input", selectRoot: "library-pagination-select-root", select: "library-pagination-select", selectIcon: "library-pagination-select-icon", displayedRows: "library-pagination-displayed-rows", actions: "library-pagination-actions" }} slotProps={{ root: { className: "library-pagination-root-slot" }, toolbar: { className: "library-pagination-toolbar-slot" }, spacer: { className: "library-pagination-spacer-slot" }, selectLabel: { className: "library-pagination-select-label-slot" }, input: { className: "library-pagination-input-slot" }, selectRoot: { className: "library-pagination-select-root-slot" }, select: { className: "library-pagination-select-slot" }, selectIcon: { className: "library-pagination-select-icon-slot" }, displayedRows: { className: "library-pagination-displayed-rows-slot" }, actions: { className: "library-pagination-actions-slot" } }} showFirstButton showLastButton count="25" page="0" rowsPerPage="10">Classed pagination</TablePagination>
                    </TableRow>
                    <TableRow>
                      <TablePagination disabled count="25" page="0" rowsPerPage="10" showFirstButton showLastButton>Disabled pagination</TablePagination>
                    </TableRow>
                  </TableFooter>
                </Table>
              </TableContainer>
              <TablePaginationActions disabled count="25" page="0" rowsPerPage="10" showFirstButton showLastButton>Disabled pagination actions</TablePaginationActions>
              <TablePaginationActions className="library-pagination-actions-root" classes={{ root: "library-pagination-actions-root-class", previousButton: "library-pagination-previous-button", previousButtonIcon: "library-pagination-previous-button-icon", nextButton: "library-pagination-next-button", nextButtonIcon: "library-pagination-next-button-icon", firstButton: "library-pagination-first-button", firstButtonIcon: "library-pagination-first-button-icon", lastButton: "library-pagination-last-button", lastButtonIcon: "library-pagination-last-button-icon" }} slotProps={{ root: { className: "library-pagination-actions-root-slot" }, previousButton: { className: "library-pagination-previous-button-slot" }, previousButtonIcon: { className: "library-pagination-previous-button-icon-slot" }, nextButton: { className: "library-pagination-next-button-slot" }, nextButtonIcon: { className: "library-pagination-next-button-icon-slot" }, firstButton: { className: "library-pagination-first-button-slot" }, firstButtonIcon: { className: "library-pagination-first-button-icon-slot" }, lastButton: { className: "library-pagination-last-button-slot" }, lastButtonIcon: { className: "library-pagination-last-button-icon-slot" } }} showFirstButton showLastButton>Classed pagination actions</TablePaginationActions>
            </CardContent>
            <CardActions>
              <Button>Open</Button>
            </CardActions>
            <CardActions disableSpacing>
              <Button>Tight card action</Button>
            </CardActions>
          </Card>
          <Card raised>
            <CardContent>
              <Typography>Raised card content</Typography>
            </CardContent>
          </Card>
        </Stack>
      </Paper>
    </Container>
  </section>

  fn record_click() {
    clicks = clicks + 1;
    render();
  }
</Component>
