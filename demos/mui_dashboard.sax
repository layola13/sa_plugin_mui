<Component name="MuiDashboard">
  <section className="mui-basic-demo mui-dashboard">
    <InitColorSchemeScript />
    <GlobalStyles />
    <CssBaseline />

    <div className="mui-dashboard-shell">
      <aside className="mui-dashboard-sidebar">
        <div className="mui-dashboard-brand">
          <div className="mui-dashboard-mark">S</div>
          <div>
            <h3>SA MUI</h3>
            <p>Component dashboard</p>
          </div>
        </div>
        <nav className="mui-dashboard-nav">
          <a href="#overview">Overview</a>
          <a href="#layout">Layout</a>
          <a href="#actions">Actions</a>
          <a href="#forms">Forms</a>
          <a href="#navigation">Navigation</a>
          <a href="#feedback">Feedback</a>
          <a href="#data">Data display</a>
        </nav>
        <div className="mui-dashboard-status">
          <h3>Coverage</h3>
          <strong>100%</strong>
          <p>SA/SAX driven</p>
        </div>
      </aside>

      <main className="mui-dashboard-main">
        <header className="mui-dashboard-topbar">
          <div>
            <p>Material UI on SA React</p>
            <h1>SA MUI Component Dashboard</h1>
          </div>
          <div className="mui-dashboard-actions">
            <span>Library build</span>
            <span>No Node MUI runtime</span>
          </div>
        </header>

        <section id="overview" className="mui-dashboard-hero">
          <div className="mui-dashboard-hero-copy">
            <h2>React-shaped, SA-owned MUI surface</h2>
            <p>Every tile below is rendered through SA React and the local SAX Material component library.</p>
          </div>
          <div className="mui-dashboard-metrics">
            <div><span>Components</span><strong>130</strong><p>Core exports</p></div>
            <div><span>Owner state</span><strong>Locked</strong><p>Verified DOM</p></div>
            <div><span>Plugin boundary</span><strong>Clean</strong><p>Zig descriptor only</p></div>
          </div>
        </section>

        <section id="layout" className="mui-dashboard-section">
          <div className="mui-section-heading">
            <h2>Layout and Surfaces</h2>
            <p>Containers, app bars, typography, paper, dividers, and utility wrappers.</p>
          </div>
          <div className="mui-showcase-grid">
            <div className="mui-showcase-card">
              <h3>Containers</h3>
              <Container fixed disableGutters>
                <Typography>Fixed flush container</Typography>
              </Container>
              <Container maxWidth="md">
                <Typography>Medium container</Typography>
              </Container>
            </div>

            <div className="mui-showcase-card">
              <h3>App bar and toolbar</h3>
              <AppBar>
                <Toolbar>
                  <Typography>Toolbar title</Typography>
                </Toolbar>
                <Toolbar variant="dense">
                  <Typography>Dense toolbar</Typography>
                </Toolbar>
                <Toolbar disableGutters>
                  <Typography>Flush toolbar</Typography>
                </Toolbar>
              </AppBar>
              <AppBar color="secondary" position="static">
                <Toolbar>
                  <Typography>Static secondary app bar</Typography>
                </Toolbar>
              </AppBar>
            </div>

            <div className="mui-showcase-card">
              <h3>Typography</h3>
              <Typography>SA driven MUI</Typography>
              <Typography gutterBottom noWrap>Compact headline</Typography>
              <Typography variant="h6">Section heading</Typography>
              <Typography align="center">Centered body copy</Typography>
            </div>

            <div className="mui-showcase-card">
              <h3>Paper and box</h3>
              <Paper variant="outlined">Outlined paper</Paper>
              <Paper elevation={3}>Elevation three paper</Paper>
              <Paper square>Square paper</Paper>
              <Box>Box content</Box>
            </div>

            <div className="mui-showcase-card">
              <h3>Dividers</h3>
              <Divider />
              <Divider absolute flexItem />
              <Divider variant="middle" />
              <Divider variant="inset" />
              <Divider orientation="vertical" flexItem />
              <Divider textAlign="left" />
            </div>

            <div className="mui-showcase-card">
              <h3>Baseline wrappers</h3>
              <ScopedCssBaseline>
                <Grid>
                  <NoSsr>Client content</NoSsr>
                  <ClickAwayListener>Click away content</ClickAwayListener>
                  <Unstable_TrapFocus open>Focus content</Unstable_TrapFocus>
                </Grid>
              </ScopedCssBaseline>
            </div>
          </div>
        </section>

        <section id="actions" className="mui-dashboard-section">
          <div className="mui-section-heading">
            <h2>Actions</h2>
            <p>Buttons, icons, fabs, grouped controls, links, and symbol components.</p>
          </div>
          <div className="mui-showcase-grid">
            <div className="mui-showcase-card">
              <h3>Buttons</h3>
              <Stack>
                <Button>Save</Button>
                <Button disabled>Disabled button</Button>
                <Button size="small">Small button</Button>
                <Button size="large">Large button</Button>
                <Button variant="contained">Contained button</Button>
                <Button color="inherit">Inherit button</Button>
                <Button color="secondary">Secondary button</Button>
              </Stack>
            </div>

            <div className="mui-showcase-card">
              <h3>Button groups</h3>
              <ButtonGroup>
                <ButtonBase>Base</ButtonBase>
                <ButtonBase disabled>Disabled base</ButtonBase>
                <Button>Grouped</Button>
              </ButtonGroup>
              <ButtonGroup variant="contained" color="inherit">
                <Button>Contained inherit grouped</Button>
              </ButtonGroup>
              <ButtonGroup color="secondary">
                <Button>Secondary grouped</Button>
              </ButtonGroup>
              <ButtonGroup orientation="vertical">
                <Button>Vertical grouped</Button>
              </ButtonGroup>
              <ButtonGroup fullWidth disableElevation>
                <Button>Full width grouped</Button>
              </ButtonGroup>
            </div>

            <div className="mui-showcase-card">
              <h3>Icon buttons</h3>
              <IconButton>Icon</IconButton>
              <IconButton color="primary">Primary icon</IconButton>
              <IconButton color="secondary">Secondary icon</IconButton>
              <IconButton color="inherit">Inherit icon</IconButton>
              <IconButton size="small">Small icon</IconButton>
              <IconButton disabled>Disabled icon</IconButton>
            </div>

            <div className="mui-showcase-card">
              <h3>Floating actions</h3>
              <Fab>Add</Fab>
              <Fab color="primary">Primary fab</Fab>
              <Fab color="secondary">Secondary fab</Fab>
              <Fab color="inherit">Inherit fab</Fab>
              <Fab variant="extended">Extended fab</Fab>
              <Fab size="small">Small fab</Fab>
              <Fab size="medium">Medium fab</Fab>
              <Fab disabled>Disabled fab</Fab>
            </div>

            <div className="mui-showcase-card">
              <h3>Links and icons</h3>
              <SvgIcon>
                <path d="M12 2 2 22h20z" />
              </SvgIcon>
              <SvgIcon color="secondary" fontSize="small">
                <path d="M12 2 2 22h20z" />
              </SvgIcon>
              <SvgIcon fontSize="large">
                <path d="M12 2 2 22h20z" />
              </SvgIcon>
              <Icon>home</Icon>
              <Icon color="secondary" fontSize="small">menu</Icon>
              <Icon fontSize="inherit">search</Icon>
              <Link>Open link</Link>
              <Link underline="hover">Hover link</Link>
              <Link underline="none">Plain link</Link>
            </div>
          </div>
        </section>

        <section id="forms" className="mui-dashboard-section">
          <div className="mui-section-heading">
            <h2>Forms and Inputs</h2>
            <p>Labels, base inputs, selects, text fields, switches, radios, and validation states.</p>
          </div>
          <div className="mui-showcase-grid">
            <div className="mui-showcase-card">
              <h3>Labels</h3>
              <FormControl>
                <FormLabel>Email</FormLabel>
              </FormControl>
              <FormControl fullWidth>
                <FormLabel>Full width form</FormLabel>
              </FormControl>
              <FormLabel disabled error filled focused required>State form label</FormLabel>
              <FormLabel color="secondary">Secondary form label</FormLabel>
              <InputLabel>Email input</InputLabel>
              <InputLabel disabled error focused required shrink>State input label</InputLabel>
              <InputLabel size="small" variant="outlined">Outlined small input label</InputLabel>
              <InputLabel disableAnimation variant="filled">Filled static input label</InputLabel>
            </div>

            <div className="mui-showcase-card">
              <h3>Input variants</h3>
              <Input>
                <InputAdornment>$</InputAdornment>
              </Input>
              <Input>
                <InputAdornment position="end">kg</InputAdornment>
              </Input>
              <InputAdornment disablePointerEvents hiddenLabel>Hidden adornment</InputAdornment>
              <Input disabled error focused fullWidth multiline readOnly>State input</Input>
              <Input color="secondary">Secondary input</Input>
              <InputBase>Base input</InputBase>
              <InputBase disabled error focused fullWidth hiddenLabel multiline readOnly>State input base</InputBase>
              <InputBase color="secondary">Secondary base input</InputBase>
              <FilledInput>Filled input</FilledInput>
              <FilledInput disabled error focused fullWidth hiddenLabel multiline readOnly>State filled input</FilledInput>
              <FilledInput color="secondary">Secondary filled input</FilledInput>
              <OutlinedInput>Outlined input</OutlinedInput>
              <OutlinedInput disabled error focused fullWidth hiddenLabel multiline readOnly>State outlined input</OutlinedInput>
              <OutlinedInput color="secondary">Secondary outlined input</OutlinedInput>
            </div>

            <div className="mui-showcase-card">
              <h3>Fields and selects</h3>
              <TextField>Text field</TextField>
              <TextField disabled error fullWidth multiline required>State text field</TextField>
              <TextField color="secondary">Secondary text field</TextField>
              <TextareaAutosize>Textarea</TextareaAutosize>
              <Select>
                <MenuItem>First option</MenuItem>
                <MenuItem>Second option</MenuItem>
              </Select>
              <Select color="secondary">Secondary select</Select>
              <Select variant="standard">Standard select</Select>
              <Select disabled error multiple open>State select</Select>
              <NativeSelect>
                <option>Native option</option>
              </NativeSelect>
              <NativeSelect color="secondary">
                <option>Secondary native option</option>
              </NativeSelect>
              <NativeSelect variant="outlined">
                <option>Outlined native option</option>
              </NativeSelect>
              <NativeSelect disabled error multiple>
                <option>Disabled native option</option>
              </NativeSelect>
            </div>

            <div className="mui-showcase-card">
              <h3>Choice controls</h3>
              <FormGroup>
                <FormControlLabel>
                  <Checkbox />
