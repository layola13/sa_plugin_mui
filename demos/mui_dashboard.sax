                <Switch color="secondary">Secondary switch</Switch>
                <Switch checked>Checked switch</Switch>
                <Switch disabled>Disabled switch</Switch>
                <FormHelperText>Required field</FormHelperText>
                <FormHelperText size="small">Small helper text</FormHelperText>
                <FormHelperText variant="filled">Filled helper text</FormHelperText>
                <FormHelperText variant="outlined">Outlined helper text</FormHelperText>
                <FormHelperText disabled error filled focused required>State helper text</FormHelperText>
              </FormGroup>
              <FormGroup row error>
                <FormControlLabel disabled error required>
                  State form control label
                </FormControlLabel>
              </FormGroup>
              <RadioGroup>
                <Radio />
                <Radio size="small">Small radio</Radio>
                <Radio color="secondary">Secondary radio</Radio>
                <Radio checked>Checked radio</Radio>
                <Radio disabled>Disabled radio</Radio>
              </RadioGroup>
              <RadioGroup row error>
                <Radio>Row error radio</Radio>
              </RadioGroup>
